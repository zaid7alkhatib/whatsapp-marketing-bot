NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE

# Public backend URL used by the dashboard.
APP_BASE_URL=https://api.example.com

# Comma-separated frontend origins allowed to call the API.
CORS_ORIGINS=https://app.example.com

# Use a persistent mounted directory in production.
BAILEYS_AUTH_BASE_PATH=/var/lib/conversational-bot-platform/baileys-auth

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_TOKEN_SECRET=replace-with-a-strong-random-secret
AUTH_TOKEN_TTL_HOURS=168

DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=replace-with-a-strong-admin-password
DASHBOARD_USER_USERNAME=client
DASHBOARD_USER_PASSWORD=replace-with-a-strong-client-password
DASHBOARD_USER_FLOW_ID=
DASHBOARD_USER_FLOW_CODE=
DASHBOARD_USER_CHANNEL_ACCOUNT_ID=
DASHBOARD_USER_CHANNEL_ACCOUNT_CODE=
