NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/conversational-bot-platform

APP_BASE_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BAILEYS_AUTH_BASE_PATH=.baileys-auth

AUTH_TOKEN_SECRET=local-dev-change-before-production
AUTH_TOKEN_TTL_HOURS=168

DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=admin
DASHBOARD_USER_USERNAME=client
DASHBOARD_USER_PASSWORD=client
DASHBOARD_USER_CHANNEL_ACCOUNT_ID=
DASHBOARD_USER_CHANNEL_ACCOUNT_CODE=
